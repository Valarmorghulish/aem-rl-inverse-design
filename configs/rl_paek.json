    "sr_low_slope": 0.08,
    "sr_mid_anchor": 0.92,
    "sr_tail_decay": 0.12,
    "alpha_structure": 0.20,
    "diversity_window_size": 1000,
    "diversity_unique_bonus": 1.2,
    "diversity_recurrent_bonus": 1.0,
